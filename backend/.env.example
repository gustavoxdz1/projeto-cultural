# App mode: development | test | production
NODE_ENV=development

# HTTP port used by the backend process
PORT=3333

# PostgreSQL connection string (Railway/Render usually provide this)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME?schema=public

# Secret used to sign JWT tokens (use a long random value)
JWT_SECRET=change-me-to-a-long-random-secret

# Frontend public URL (fallback for CORS when CORS_ORIGINS is empty)
URL_FRONTEND=http://localhost:5173

# Allowed CORS origins separated by comma
# Example: https://app.seudominio.com,https://www.seudominio.com
CORS_ORIGINS=http://localhost:5173

# Optional: Resend API key for transactional emails
RESEND_API_KEY=

# Optional: sender email format "Name <email@domain.com>"
EMAIL_FROM=
